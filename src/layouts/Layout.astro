---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Fiches pédagogiques maker libres de droit pour MJC, centres sociaux et médiathèques. Propulsé par La Fabrique Mobile." } = Astro.props;
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="description" content={description} />
  <title>{title} — La Ressourcerie Maker</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&family=DM+Mono:wght@400;500&display=swap" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <div class="app">
    <slot />
  </div>
</body>
</html>
