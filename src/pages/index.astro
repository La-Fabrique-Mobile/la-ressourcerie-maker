---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Manifesto from '../components/Manifesto.astro';
import { getCollection } from 'astro:content';

// --- Sélection saisonnière (build-time) ---
const MOIS_CTX = [
  { saison: 'hiver',     occasions: ['intergenerationnel'],            label: 'Janvier'   },
  { saison: 'hiver',     occasions: ['intergenerationnel'],            label: 'Février'   },
  { saison: 'printemps', occasions: ['stem'],                          label: 'Mars'      },
  { saison: 'printemps', occasions: ['paques', 'fetes'],               label: 'Avril'     },
  { saison: 'printemps', occasions: ['fetes', 'kermesse'],             label: 'Mai'       },
  { saison: 'été',       occasions: ['kermesse', 'fetes', 'reemploi'], label: 'Juin'      },
  { saison: 'été',       occasions: ['kermesse'],                      label: 'Juillet'   },
  { saison: 'été',       occasions: ['kermesse'],                      label: 'Août'      },
  { saison: 'automne',   occasions: ['reemploi'],                      label: 'Septembre' },
  { saison: 'automne',   occasions: ['halloween'],                     label: 'Octobre'   },
  { saison: 'automne',   occasions: ['reemploi'],                      label: 'Novembre'  },
  { saison: 'hiver',     occasions: ['noel'],                          label: 'Décembre'  },
] as const;

const ctx = MOIS_CTX[new Date().getMonth()];
const tousAteliers = await getCollection('ateliers');

const scored = tousAteliers.map(a => {
  let score = 0;
  if (a.data.saisons?.includes(ctx.saison as any)) score += 2;
  if (a.data.occasions?.some(o => (ctx.occasions as readonly string[]).includes(o))) score += 3;
  return { a, score };
}).sort((x, y) => y.score - x.score);

const selection = scored.slice(0, 3).map(s => s.a);
const nbPlaceholders = Math.max(0, 3 - selection.length);

const FAMILLE_CLASS: Record<string, string> = {
  kermesse: '',
  carton: '',
  machines: 'ph-photo--moss',
  mediation: 'ph-photo--moss',
  beaverbot: 'ph-photo--moss',
};
const FAMILLE_LABEL: Record<string, string> = {
  kermesse: 'jeu · kermesse',
  carton: 'construction carton',
  machines: 'fabrication numérique',
  mediation: 'médiation',
  beaverbot: 'beaverbot',
};
const publicCourt = (p: string) => p.split(' · ')[0];
const dureeCourte = (d: string) => d.split(' de ')[0];
const nbReemploi = tousAteliers.filter(a => a.data.reemploi).length;
const reemploiLabel = nbReemploi >= 100 ? '100+' : String(nbReemploi);
---
<Layout title="Tous les outils pour animer des ateliers maker">
  <Nav current="home" />

  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="hero__eyebrow">
        <span class="section-eyebrow">Commun numérique</span>
      </div>
      <h1 class="hero__title">Tous les outils pour <em>animer</em> des ateliers maker.</h1>
      <p class="hero__lead">Fiches pédagogiques prêtes à l'emploi, kits de matériel, déclinaisons réemploi. Pour les MJC, centres sociaux, médiathèques et toutes les structures qui veulent faire fabriquer.</p>
      <div class="hero__cta">
        <a class="btn btn--accent" href="/catalogue">
          Explorer le catalogue
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a class="btn btn--ghost" href="/a-propos">Comment ça marche</a>
      </div>

      <!-- Visual card stack -->
      <div class="hero__visual">
        <span class="hero__sticker">+{tousAteliers.length} ateliers · libres</span>

        <div class="hero__visual-card hero__visual-card--lg ph-photo">
          <div class="hero__visual-card__inner">
            <span class="ph-photo__caption">atelier · chamboule-tout</span>
          </div>
        </div>

        <div class="hero__visual-card hero__visual-card--md">
          <div class="hero__visual-card__inner">
            <div style="display:flex;flex-direction:column;gap:6px">
              <span class="label-mono" style="color:var(--rm-orange)">Fiche · 4 étapes</span>
              <b style="font-size:14px;letter-spacing:-.01em">Bras hydraulique en carton</b>
            </div>
            <div style="display:flex;gap:4px">
              <span class="tag tag--time">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="8.5"/><path d="M12 7v5l3.5 2.5"/></svg>
                90 min
              </span>
            </div>
          </div>
        </div>

        <div class="hero__visual-card hero__visual-card--sm ph-photo ph-photo--moss">
          <div class="hero__visual-card__inner" style="padding:0;justify-content:center;align-items:center">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--rm-paper)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 13L4 18h7"/><path d="M11 18l-2-2"/>
              <path d="M17 13l3 5h-7"/><path d="M13 18l2-2"/>
              <path d="M14 7L11 5 8 7"/><path d="M11 5v6"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Stats strip -->
      <div class="hero__stats">
        <div class="hero__stat"><b>{tousAteliers.length}</b><span>ateliers</span></div>
        <div class="hero__stat"><b>♻︎ {reemploiLabel}</b><span>en réemploi</span></div>
        <div class="hero__stat"><b>CC</b><span>licence</span></div>
      </div>
    </section>

    <Manifesto />

    <!-- FEATURED WORKSHOPS -->
    <section class="section">
      <div class="section__head">
        <div>
          <span class="section-eyebrow">Sélection · {ctx.label}</span>
          <h2 style="margin-top:8px">Ateliers à essayer</h2>
        </div>
        <a href="/catalogue">Tout voir →</a>
      </div>

      <div class="workshop-grid">
        {selection.map(atelier => (
          <a class="wcard" href={`/ateliers/${atelier.slug}`}>
            <div class={`wcard__media ph-photo ${FAMILLE_CLASS[atelier.data.famille] ?? ''}`}>
              <div class="wcard__badges">
                <span class={`badge badge--${atelier.data.classification}`}>
                  {atelier.data.classification === 'classique'
                    ? <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3.2l1.5 1.1 1.8-.5.8 1.7 1.85.3.05 1.85 1.5 1.1-.7 1.7.7 1.7-1.5 1.1-.05 1.85-1.85.3-.8 1.7-1.8-.5L12 16.8l-1.5-1.1-1.8.5-.8-1.7-1.85-.3-.05-1.85L4.5 11.25l.7-1.7-.7-1.7L6 6.75l.05-1.85L7.9 4.6l.8-1.7 1.8.5L12 3.2z"/><path d="M12 7.4l1 2 2.2.3-1.6 1.55.4 2.2L12 12.4l-2 1.05.4-2.2L8.8 9.7 11 9.4l1-2z"/><path d="M9 18.5l-1.5 3 2-.3.7 1.8 1.8-3.6"/><path d="M15 18.5l1.5 3-2-.3-.7 1.8-1.8-3.6"/></svg>
                    : <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3.5c.4 3.4 1.8 4.8 5.2 5.2-3.4.4-4.8 1.8-5.2 5.2-.4-3.4-1.8-4.8-5.2-5.2 3.4-.4 4.8-1.8 5.2-5.2z"/><path d="M5.5 17c.2 1.5.9 2.2 2.4 2.4-1.5.2-2.2.9-2.4 2.4-.2-1.5-.9-2.2-2.4-2.4 1.5-.2 2.2-.9 2.4-2.4z"/><path d="M18 15.5c.2 1.6 1 2.4 2.6 2.6-1.6.2-2.4 1-2.6 2.6-.2-1.6-1-2.4-2.6-2.6 1.6-.2 2.4-1 2.6-2.6z"/></svg>
                  }
                  {atelier.data.classification === 'classique' ? 'Classique' : 'Original'}
                </span>
              </div>
              {atelier.data.reemploi && (
                <div class="wcard__reuse">
                  <span class="tag tag--reuse">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M7 13L4 18h7"/><path d="M11 18l-2-2"/>
                      <path d="M17 13l3 5h-7"/><path d="M13 18l2-2"/>
                      <path d="M14 7L11 5 8 7"/><path d="M11 5v6"/>
                    </svg>
                    Réemploi
                  </span>
                </div>
              )}
              <span class="ph-photo__caption">{FAMILLE_LABEL[atelier.data.famille] ?? atelier.data.famille}</span>
            </div>
            <div class="wcard__body">
              <h3 class="wcard__title">{atelier.data.titre}</h3>
              <p class="wcard__hint">{atelier.data.accroche}</p>
              <div class="wcard__tags">
                <span class="tag tag--public">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="9" cy="9" r="3"/><path d="M3 19c0-3.3 2.7-6 6-6s6 2.7 6 6"/>
                    <circle cx="17" cy="7" r="2.5"/><path d="M14 14c2.7 0 6 1.7 6 5"/>
                  </svg>
                  {publicCourt(atelier.data.public)}
                </span>
                <span class="tag tag--time">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="8.5"/><path d="M12 7v5l3.5 2.5"/>
                  </svg>
                  {dureeCourte(atelier.data.duree)}
                </span>
              </div>
            </div>
          </a>
        ))}

        {Array.from({ length: nbPlaceholders }).map(() => (
          <div class="wcard wcard--soon">
            <div class="wcard__media ph-photo ph-photo--muted">
              <div class="wcard__badges">
                <span class="badge badge--soon">Bientôt</span>
              </div>
            </div>
            <div class="wcard__body">
              <p class="wcard__title" style="color:var(--text-3)">Prochain atelier</p>
              <p class="wcard__hint" style="color:var(--text-3)">De nouveaux ateliers arrivent bientôt dans le catalogue.</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- RESOURCES -->
    <section class="resources">
      <div class="resources__inner">
      <div class="resources__head" style="margin-bottom:22px">
        <span class="section-eyebrow">Au-delà des fiches</span>
        <h2 style="font-size:26px;margin-top:8px;letter-spacing:-.025em">Ressources transversales</h2>
        <p style="font-size:15px;color:var(--text-2);margin-top:8px;max-width:40ch">Trois entrées pour outiller votre posture d'animateur·rice maker, au-delà de l'atelier.</p>
      </div>
      <div class="resources__list">
        <a class="resource-card" href="/ressources/pedagogie-maker">
          <span class="resource-card__pic">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--rm-kraft-deep)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 17h6M10 20h4"/>
              <path d="M8 13c-1.5-1.3-2.5-3-2.5-5C5.5 4.5 8.4 2 12 2s6.5 2.5 6.5 6c0 2-1 3.7-2.5 5v3h-8v-3z"/>
            </svg>
          </span>
          <div>
            <h3 class="resource-card__title">Pédagogie maker</h3>
            <p class="resource-card__desc">La culture du faire, du rater, du recommencer — guide pour animer sans donner la leçon.</p>
          </div>
          <svg class="resource-card__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>

        <a class="resource-card resource-card--orange" href="/ressources/kit-de-base">
          <span class="resource-card__pic">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--rm-terracotta)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 8l8-4 8 4v9l-8 4-8-4z"/>
              <path d="M4 8l8 4M20 8l-8 4M12 12v9"/>
            </svg>
          </span>
          <div>
            <h3 class="resource-card__title">Kit de base</h3>
            <p class="resource-card__desc">L'outillage minimum pour démarrer un coin maker : 220 € de matériel, 12 ateliers couverts.</p>
          </div>
          <svg class="resource-card__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>

        <a class="resource-card resource-card--moss" href="/ressources/reemploi">
          <span class="resource-card__pic">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--rm-moss)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 13L4 18h7"/><path d="M11 18l-2-2"/>
              <path d="M17 13l3 5h-7"/><path d="M13 18l2-2"/>
              <path d="M14 7L11 5 8 7"/><path d="M11 5v6"/>
            </svg>
          </span>
          <div>
            <h3 class="resource-card__title">Thématique réemploi</h3>
            <p class="resource-card__desc">Faire avec ce qu'on a — sourcing local, déchets industriels, partenariats ressourcerie.</p>
          </div>
          <svg class="resource-card__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
      </div>
    </section>
    <!-- NEWSLETTER CTA -->
    <section class="newsletter-cta">
      <div class="newsletter-cta__inner">
        <div class="newsletter-cta__content">
          <div class="newsletter-cta__eyebrow">Newsletter · mensuelle · gratuite</div>
          <h2 class="newsletter-cta__title">La plateforme<br>qui vient à vous.</h2>
          <p class="newsletter-cta__desc">Nouveaux ateliers, angle saisonnier et ressource pédagogique — chaque mois, sans avoir à chercher.</p>
          <div class="newsletter-cta__perks">
            <span class="newsletter-cta__perk">Angle saisonnier</span>
            <span class="newsletter-cta__perk">Nouveaux ateliers</span>
            <span class="newsletter-cta__perk">Ressource pédago</span>
            <span class="newsletter-cta__perk">Gratuit</span>
          </div>
        </div>
        <div class="newsletter-cta__actions">
          <a class="btn btn--nl" href="/newsletter">
            S'inscrire
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <p class="newsletter-cta__note">Gratuit · résiliable à tout moment</p>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
.wcard--soon {
  pointer-events: none;
  cursor: default;
}
.ph-photo--muted {
  background: var(--rm-cream-2);
  background-image: none;
}
.badge--soon {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: .06em;
  padding: 3px 8px;
  border-radius: 20px;
  border: 1px dashed var(--rm-kraft);
  background: transparent;
  color: var(--text-3);
}

/* Breathing between sections */
:global(.manifesto),
.section,
.resources,
.newsletter-cta {
  margin-top: 40px;
}

@media (min-width: 880px) {
  :global(.manifesto),
  .section,
  .resources,
  .newsletter-cta {
    margin-top: 72px;
  }
}
</style>
