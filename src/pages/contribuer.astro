---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="Contribuer — La Ressourcerie Maker"
  description="Comment contribuer à La Ressourcerie Maker : signaler une erreur, proposer un atelier ou une ressource, améliorer le code. Via Framagit ou par mail."
>
  <Nav />

  <main class="page">

    <!-- HERO -->
    <section class="co-hero">
      <span class="section-eyebrow">Commun numérique · ouvert</span>
      <h1 class="co-hero__title">Contribuer</h1>
      <p class="co-hero__lead">La Ressourcerie Maker est un commun — elle vit de ce que ses utilisateurs y apportent. Corriger une erreur, proposer un atelier, améliorer une fiche : chaque contribution compte, quelle que soit sa taille.</p>
    </section>

    <!-- 3 FAÇONS -->
    <section class="section" style="padding-top:0">
      <h2 style="margin-bottom:20px">3 façons de contribuer</h2>

      <div class="co-ways">

        <!-- 1. Signaler -->
        <div class="co-way co-way--1">
          <div class="co-way__num">1</div>
          <div class="co-way__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <path d="M12 9v4M12 17h.01"/>
            </svg>
          </div>
          <h3>Signaler un problème</h3>
          <p>Une erreur dans une fiche, un lien cassé, une information périmée, un bug d'affichage. Le plus simple : ouvrir une <em>issue</em> sur Framagit avec une description du problème.</p>
          <div class="co-way__actions">
            <a class="btn btn--accent" href="https://framagit.org/la-fabrique-mobile/la-ressourcerie-maker/-/issues/new" target="_blank" rel="noopener">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
              Ouvrir une issue
            </a>
            <a class="co-alt-link" href="mailto:bonjour.lafabriquemobile@gmail.com">
              ou par mail →
            </a>
          </div>
        </div>

        <!-- 2. Proposer -->
        <div class="co-way co-way--2">
          <div class="co-way__num">2</div>
          <div class="co-way__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <path d="M14 2v6h6M12 18v-6M9 15l3 3 3-3"/>
            </svg>
          </div>
          <h3>Proposer un atelier ou une ressource</h3>
          <p>Vous animez des ateliers maker et vous avez une fiche qui tourne bien ? Une thématique qui manque ? Envoyez-nous un message — on discutera du format et de l'intégration.</p>
          <div class="co-way__checklist">
            <span class="co-check">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
              Fiche d'atelier testée en conditions réelles
            </span>
            <span class="co-check">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
              Contenu adaptable à différents publics
            </span>
            <span class="co-check">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
              Compatible licence CC BY-SA 4.0
            </span>
          </div>
          <div class="co-way__actions">
            <a class="btn btn--accent" href="mailto:bonjour.lafabriquemobile@gmail.com?subject=Proposition%20de%20contribution%20—%20La%20Ressourcerie%20Maker">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
              Écrire un mail
            </a>
            <a class="co-alt-link" href="https://framagit.org/la-fabrique-mobile/la-ressourcerie-maker/-/issues/new" target="_blank" rel="noopener">
              ou via Framagit →
            </a>
          </div>
        </div>

        <!-- 3. Code -->
        <div class="co-way co-way--3">
          <div class="co-way__num">3</div>
          <div class="co-way__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M16 18l6-6-6-6M8 6l-6 6 6 6"/>
            </svg>
          </div>
          <h3>Améliorer le code</h3>
          <p>La plateforme tourne sur Astro, CSS vanilla, zéro framework JS côté client. Accessible aux débutants comme aux développeurs expérimentés.</p>
          <div class="co-way__steps">
            <div class="co-step"><span>1</span>Fork le dépôt sur Framagit</div>
            <div class="co-step"><span>2</span>Crée une branche pour ta modification</div>
            <div class="co-step"><span>3</span>Ouvre une Merge Request avec une description claire</div>
          </div>
          <div class="co-way__actions">
            <a class="btn btn--accent" href="https://framagit.org/la-fabrique-mobile/la-ressourcerie-maker" target="_blank" rel="noopener">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
              Voir le dépôt Framagit
            </a>
          </div>
        </div>

      </div>
    </section>

    <!-- PROCESSUS -->
    <section class="section">
      <h2 style="margin-bottom:8px">Comment ça se passe</h2>
      <p class="co-intro">Pas de processus lourd. Une contribution typique ressemble à ça :</p>

      <div class="co-process">
        <div class="co-process-step">
          <div class="co-process-step__dot"></div>
          <div>
            <b>Contact initial</b>
            <p>Mail ou issue Framagit — décrivez votre idée en 2–3 lignes. On répond dans la semaine.</p>
          </div>
        </div>
        <div class="co-process-step">
          <div class="co-process-step__dot"></div>
          <div>
            <b>Discussion</b>
            <p>On échange sur le format, le public cible, l'intégration dans le catalogue. C'est souvent rapide.</p>
          </div>
        </div>
        <div class="co-process-step">
          <div class="co-process-step__dot"></div>
          <div>
            <b>Intégration</b>
            <p>On s'occupe de la mise en forme technique (fichier Markdown structuré, fiche PDF). Votre rôle : le contenu.</p>
          </div>
        </div>
        <div class="co-process-step co-process-step--last">
          <div class="co-process-step__dot"></div>
          <div>
            <b>Publication avec crédit</b>
            <p>La fiche est publiée sous CC BY-SA 4.0 avec mention de la source et de l'auteur·ice.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ESPRIT -->
    <section class="manifesto">
      <div class="manifesto__inner">
        <div>
          <div class="manifesto__eyebrow">L'esprit du commun</div>
          <div class="manifesto__sign">— La Ressourcerie Maker</div>
        </div>
        <p class="manifesto__text">
          Ce projet ne cherche pas la perfection — il cherche l'<em>utilité</em>. Une fiche imparfaite qui aide quelqu'un à animer un atelier demain vaut plus qu'une fiche parfaite qui n'existe pas encore.
        </p>
      </div>
    </section>

    <!-- CONTACT -->
    <section class="section">
      <h2 style="margin-bottom:16px">Une question ?</h2>

      <div class="co-contacts">
        <a class="co-contact" href="mailto:bonjour.lafabriquemobile@gmail.com">
          <div class="co-contact__icon co-contact__icon--mail">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <path d="M22 6l-10 7L2 6"/>
            </svg>
          </div>
          <div>
            <span class="co-contact__label">Mail</span>
            <span class="co-contact__value">bonjour.lafabriquemobile@gmail.com</span>
          </div>
        </a>
        <a class="co-contact" href="https://framagit.org/la-fabrique-mobile/la-ressourcerie-maker/-/issues" target="_blank" rel="noopener">
          <div class="co-contact__icon co-contact__icon--git">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/>
            </svg>
          </div>
          <div>
            <span class="co-contact__label">Issues Framagit</span>
            <span class="co-contact__value">framagit.org · la-ressourcerie-maker</span>
          </div>
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
/* Hero */
.co-hero {
  padding: 48px 22px 40px;
  border-bottom: 1px solid var(--rm-kraft-soft);
}
.co-hero__title {
  font-size: clamp(40px, 9vw, 64px);
  line-height: 1;
  letter-spacing: -0.04em;
  margin: 12px 0 16px;
}
.co-hero__lead {
  font-size: 17px;
  line-height: 1.6;
  color: var(--text-2);
  max-width: 52ch;
}

.co-intro {
  font-size: 15px;
  color: var(--text-2);
  line-height: 1.6;
  margin-bottom: 20px;
}

/* Ways */
.co-ways { display: grid; gap: 12px; }
.co-way {
  background: var(--rm-paper);
  border: 1.5px solid var(--rm-kraft-soft);
  border-radius: var(--r-xl);
  padding: 24px 20px 20px;
  position: relative;
}
.co-way__num {
  position: absolute;
  top: -1px; left: -1px;
  width: 28px; height: 28px;
  border-radius: var(--r-xl) 0 var(--r-md) 0;
  background: var(--rm-ink);
  color: var(--rm-cream);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 13px;
  display: grid;
  place-items: center;
}
.co-way__icon {
  width: 48px; height: 48px;
  border-radius: 13px;
  display: grid;
  place-items: center;
  margin-bottom: 16px;
  margin-top: 8px;
}
.co-way--1 .co-way__icon { background: #FEF3C7; color: #92600A; }
.co-way--2 .co-way__icon { background: var(--rm-moss-soft); color: var(--rm-moss); }
.co-way--3 .co-way__icon { background: #F0E6D6; color: var(--rm-kraft-deep); }
.co-way h3 { font-size: 18px; letter-spacing: -0.02em; margin-bottom: 10px; }
.co-way p { font-size: 14px; color: var(--text-2); line-height: 1.6; margin-bottom: 14px; }

.co-way__checklist {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 16px;
}
.co-check {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: var(--text-2);
}
.co-check svg { flex: none; color: var(--rm-moss); }

.co-way__steps {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 16px;
}
.co-step {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  color: var(--text-2);
}
.co-step span {
  flex: none;
  width: 22px; height: 22px;
  border-radius: 50%;
  background: #F0E6D6;
  color: var(--rm-kraft-deep);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 11px;
  display: grid;
  place-items: center;
}

.co-way__actions {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
}
.co-alt-link {
  font-size: 13.5px;
  color: var(--text-3);
  text-decoration: none;
  font-weight: 500;
}
.co-alt-link:hover { color: var(--text-1); }

/* Process */
.co-process {
  display: flex;
  flex-direction: column;
  position: relative;
  padding-left: 28px;
}
.co-process::before {
  content: '';
  position: absolute;
  left: 8px;
  top: 12px;
  bottom: 12px;
  width: 1.5px;
  background: var(--rm-kraft-soft);
}
.co-process-step {
  display: flex;
  gap: 16px;
  padding-bottom: 24px;
  position: relative;
}
.co-process-step--last { padding-bottom: 0; }
.co-process-step__dot {
  flex: none;
  width: 16px; height: 16px;
  border-radius: 50%;
  background: var(--rm-orange);
  border: 3px solid var(--rm-cream);
  box-shadow: 0 0 0 1.5px var(--rm-orange);
  position: absolute;
  left: -24px;
  top: 3px;
}
.co-process-step b { font-size: 15px; display: block; margin-bottom: 4px; }
.co-process-step p { font-size: 13.5px; color: var(--text-2); line-height: 1.6; margin: 0; }

/* Contacts */
.co-contacts { display: grid; gap: 10px; }
.co-contact {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 18px 20px;
  background: var(--rm-paper);
  border: 1.5px solid var(--rm-kraft-soft);
  border-radius: var(--r-lg);
  text-decoration: none;
  color: inherit;
  transition: border-color .15s, box-shadow .15s;
}
.co-contact:hover {
  border-color: var(--rm-ink);
  box-shadow: 0 2px 0 0 var(--rm-ink);
}
.co-contact__icon {
  flex: none;
  width: 42px; height: 42px;
  border-radius: 11px;
  display: grid;
  place-items: center;
}
.co-contact__icon--mail { background: var(--rm-moss-soft); color: var(--rm-moss); }
.co-contact__icon--git  { background: #F0E6D6; color: var(--rm-kraft-deep); }
.co-contact__label {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--text-3);
  display: block;
  margin-bottom: 2px;
}
.co-contact__value {
  font-size: 14px;
  font-weight: 600;
  color: var(--rm-orange);
  letter-spacing: -0.01em;
}

/* Desktop */
@media (min-width: 880px) {
  .co-hero { padding: 80px 64px 56px; max-width: 1320px; margin: 0 auto; }
  .co-hero__title { font-size: clamp(56px, 5.5vw, 80px); }
  .co-hero__lead { font-size: 20px; }

  .co-ways { grid-template-columns: 1fr 1fr 1fr; }
  .co-contacts { grid-template-columns: 1fr 1fr; }

  .co-process {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 32px;
    padding-left: 0;
  }
  .co-process::before { display: none; }
  .co-process-step { padding-left: 0; }
  .co-process-step__dot { display: none; }
  .co-process-step { padding-bottom: 0; border-left: 3px solid var(--rm-kraft-soft); padding-left: 20px; }
  .co-process-step b::before { display: none; }
}
</style>
