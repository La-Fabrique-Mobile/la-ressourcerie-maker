---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="À propos"
  description="La Ressourcerie Maker est un commun numérique de fiches pédagogiques maker, libres de droit, pour les MJC, centres sociaux et médiathèques."
>
  <Nav current="about" />

  <main class="page">

    <!-- EN-TÊTE -->
    <section class="about-hero">
      <span class="section-eyebrow">Le projet</span>
      <h1 class="about-hero__title">Un commun numérique<br>pour animer le faire.</h1>
      <p class="about-hero__lead">La Ressourcerie Maker rassemble des fiches pédagogiques maker libres de droit, des kits de matériel et des ressources pour tous les animateurs et structures qui veulent lancer des ateliers — sans repartir de zéro.</p>
    </section>

    <!-- PARTI PRIS -->
    <section class="manifesto">
      <div class="manifesto__inner">
        <div>
          <div class="manifesto__eyebrow">Notre parti pris</div>
          <div class="manifesto__sign">— Ressourcerie Maker · 2026</div>
        </div>
        <p class="manifesto__text">
          Le matériel coûte cher. Le savoir-faire, lui, peut <em>circuler librement</em>. Ce qu'on partage ici : nos ratés, nos protocoles, nos astuces de récup'.
        </p>
      </div>
    </section>

    <!-- POUR QUI -->
    <section class="section">
      <div class="section__head">
        <div>
          <span class="section-eyebrow">Public</span>
          <h2 style="margin-top:8px">Pour qui ?</h2>
        </div>
      </div>
      <div class="resources__list">
        <div class="resource-card" style="text-decoration:none">
          <span class="resource-card__pic">
            <!-- Immeuble / structure -->
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--rm-kraft-deep)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M9 3v18M15 3v18M3 9h18M3 15h18"/>
            </svg>
          </span>
          <div>
            <h3 class="resource-card__title">MJC &amp; centres sociaux</h3>
            <p class="resource-card__desc">Des ateliers adaptés aux groupes hétérogènes, aux animations de quartier et aux séquences sur plusieurs semaines.</p>
          </div>
        </div>

        <div class="resource-card resource-card--orange" style="text-decoration:none">
          <span class="resource-card__pic">
            <!-- Livre / médiathèque -->
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--rm-terracotta)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
          </span>
          <div>
            <h3 class="resource-card__title">Médiathèques</h3>
            <p class="resource-card__desc">Des formats courts et autonomes pour les espaces numériques, les publics en autonomie, et les animations hors les murs.</p>
          </div>
        </div>

        <div class="resource-card resource-card--moss" style="text-decoration:none">
          <span class="resource-card__pic">
            <!-- Groupe / animateurs -->
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--rm-moss)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="9" cy="9" r="3"/><path d="M3 19c0-3.3 2.7-6 6-6s6 2.7 6 6"/>
              <circle cx="17" cy="7" r="2.5"/><path d="M14 14c2.7 0 6 1.7 6 5"/>
            </svg>
          </span>
          <div>
            <h3 class="resource-card__title">Animateurs &amp; éducateurs</h3>
            <p class="resource-card__desc">Des fiches prêtes à l'emploi, avec le matériel, les étapes et les déclinaisons — pour animer en confiance même sans machine.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- COMMENT ÇA MARCHE -->
    <section class="section" style="padding-top:0">
      <div class="section__head">
        <div>
          <span class="section-eyebrow">Mode d'emploi</span>
          <h2 style="margin-top:8px">Comment ça marche</h2>
        </div>
      </div>
      <div class="about-steps">

        <div class="about-step">
          <div class="about-step__num">01</div>
          <div class="about-step__body">
            <h3 class="about-step__title">Choisissez un atelier</h3>
            <p class="about-step__desc">Parcourez le catalogue, filtrez par public, durée ou matériel disponible. Chaque fiche indique le niveau, les machines nécessaires (ou non) et s'il existe une version réemploi.</p>
          </div>
        </div>

        <div class="about-step">
          <div class="about-step__num">02</div>
          <div class="about-step__body">
            <h3 class="about-step__title">Téléchargez la fiche</h3>
            <p class="about-step__desc">Chaque atelier est disponible en PDF imprimable — format A4, lisible en atelier, avec le pas-à-pas illustré, le matériel et les variantes.</p>
          </div>
        </div>

        <div class="about-step">
          <div class="about-step__num">03</div>
          <div class="about-step__body">
            <h3 class="about-step__title">Adaptez et partagez</h3>
            <p class="about-step__desc">Licence CC BY-SA 4.0 — reprenez, modifiez, publiez vos déclinaisons. Signalez ce qui ne marche pas, proposez des variantes, contribuez au catalogue.</p>
          </div>
        </div>

      </div>
    </section>

    <!-- LICENCE -->
    <section class="about-licence">
      <div class="about-licence__inner">
        <div class="about-licence__badge">
          <span class="about-licence__cc">CC</span>
          <span class="about-licence__icons">BY SA</span>
        </div>
        <div>
          <h3 class="about-licence__title">Licence Creative Commons BY-SA 4.0</h3>
          <p class="about-licence__text">Tout le contenu de La Ressourcerie Maker est publié sous licence ouverte. Vous pouvez l'utiliser, le modifier et le redistribuer librement — à condition de citer la source et de partager vos modifications sous la même licence.</p>
        </div>
      </div>
    </section>

    <!-- PROPULSÉ PAR LFM -->
    <section class="section">
      <div class="about-lfm">
        <div class="about-lfm__logo">
          <svg width="18" height="18" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 27V7h7c2.5 0 4 1.7 4 4 0 2.3-1.5 4-4 4H5"/>
            <path d="M12 15l5 12"/>
            <path d="M21 27v-7l3 7 3-7v7"/>
          </svg>
        </div>
        <div>
          <p class="about-lfm__label">Propulsé par</p>
          <p class="about-lfm__name">La Fabrique Mobile</p>
          <p class="about-lfm__desc">Fablab itinérant basé à Lyon. Ateliers de fabrication numérique et low-tech pour centres sociaux, MJC, médiathèques et événements.</p>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
/* ---- About hero ---- */
.about-hero {
  padding: 48px 22px 32px;
}
.about-hero__title {
  font-size: clamp(32px, 8vw, 44px);
  line-height: 1.05;
  letter-spacing: -0.035em;
  margin: 16px 0 18px;
  font-weight: 700;
}
.about-hero__lead {
  font-size: 17px;
  line-height: 1.6;
  color: var(--text-2);
  max-width: 50ch;
}

/* ---- Steps ---- */
.about-steps {
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 1.5px solid var(--rm-kraft);
  border-radius: var(--r-lg);
  overflow: hidden;
  background: var(--rm-paper);
}
.about-step {
  display: flex;
  gap: 18px;
  padding: 22px 20px;
  border-bottom: 1px solid var(--rm-kraft-soft);
}
.about-step:last-child { border-bottom: 0; }
.about-step__num {
  font-family: var(--font-mono);
  font-size: 13px;
  font-weight: 500;
  color: var(--rm-orange);
  letter-spacing: .06em;
  flex: none;
  padding-top: 3px;
  width: 28px;
}
.about-step__title {
  font-size: 17px;
  font-weight: 700;
  letter-spacing: -0.01em;
  margin-bottom: 6px;
}
.about-step__desc {
  font-size: 14px;
  color: var(--text-2);
  line-height: 1.55;
}

/* ---- Licence ---- */
.about-licence {
  background: var(--rm-cream-2);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 32px 22px;
}
.about-licence__inner {
  display: flex;
  gap: 18px;
  align-items: flex-start;
}
.about-licence__badge {
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 56px;
  height: 56px;
  border-radius: 12px;
  background: var(--rm-ink);
  color: var(--rm-cream);
  gap: 2px;
}
.about-licence__cc {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 16px;
  letter-spacing: -.02em;
  line-height: 1;
}
.about-licence__icons {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: .1em;
  opacity: .65;
}
.about-licence__title {
  font-size: 16px;
  font-weight: 700;
  letter-spacing: -0.01em;
  margin-bottom: 6px;
}
.about-licence__text {
  font-size: 13.5px;
  color: var(--text-2);
  line-height: 1.55;
}

/* ---- LFM ---- */
.about-lfm {
  display: flex;
  gap: 16px;
  align-items: flex-start;
  padding: 20px 18px;
  border: 1.5px dashed var(--rm-kraft);
  border-radius: var(--r-md);
  background: var(--rm-paper);
}
.about-lfm__logo {
  flex: none;
  width: 38px; height: 38px;
  border-radius: 9px;
  background: var(--rm-orange);
  color: var(--rm-paper);
  display: grid; place-items: center;
}
.about-lfm__label {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--text-3);
  margin-bottom: 2px;
}
.about-lfm__name {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 16px;
  letter-spacing: -0.01em;
  margin-bottom: 4px;
}
.about-lfm__desc {
  font-size: 13px;
  color: var(--text-2);
  line-height: 1.5;
}

/* ---- Desktop ---- */
@media (min-width: 880px) {
  .about-hero {
    padding: 80px 64px 56px;
    max-width: 1320px;
    margin: 0 auto;
  }
  .about-hero__title { font-size: clamp(48px, 5vw, 72px); }
  .about-hero__lead { font-size: 20px; max-width: 56ch; }

  .about-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }
  .about-step {
    flex-direction: column;
    gap: 12px;
    padding: 28px 26px;
    border-bottom: 0;
    border-right: 1px solid var(--rm-kraft-soft);
  }
  .about-step:last-child { border-right: 0; }
  .about-step__num { width: auto; font-size: 14px; }
  .about-step__title { font-size: 18px; }

  .about-licence { padding: 40px 64px; }
  .about-licence__inner {
    max-width: 1320px;
    margin: 0 auto;
    gap: 28px;
    align-items: center;
  }
  .about-licence__badge { width: 64px; height: 64px; border-radius: 14px; }
  .about-licence__cc { font-size: 20px; }
  .about-licence__title { font-size: 18px; }
  .about-licence__text { font-size: 15px; }

  .about-lfm { padding: 28px 32px; gap: 20px; align-items: center; }
  .about-lfm__logo { width: 46px; height: 46px; border-radius: 12px; }
}
</style>
