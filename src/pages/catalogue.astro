---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Picto from '../components/Picto.astro';
import FilterDropdown from '../components/FilterDropdown.astro';
import type { DropdownOption } from '../components/FilterDropdown.astro';

const ateliers = await getCollection('ateliers');
const total = ateliers.length;

const publicLabel: Record<string, string> = {
  'enfants': 'Enfants',
  'ados':    'Ados',
  'adultes': 'Adultes',
  'famille': 'Famille',
};

const dureeLabel: Record<string, string> = {
  'flux-ouvert': '⚡ Flux ouvert',
  'atelier':     '🕐 Atelier',
  'stage':       '📅 Stage / Projet',
};

const difficulteLabel: Record<string, string> = {
  'debutant':      '⭐ Débutant',
  'intermediaire': '⭐⭐ Intermédiaire',
  'avance':        '⭐⭐⭐ Avancé',
};

const DIFF_OPTIONS: DropdownOption[] = [
  {
    value: 'tous',
    label: 'Toute difficulté',
    desc: 'Afficher tous les niveaux',
    icon: '<path d="M4 6h16M7 12h10M10 18h4"/>',
  },
  {
    value: 'debutant',
    label: '⭐ Débutant',
    desc: 'Aucune expérience requise',
    icon: '<rect x="3" y="17" width="4" height="4" rx="1" fill="currentColor" stroke="none"/><rect x="10" y="11" width="4" height="10" rx="1" fill="currentColor" stroke="none" opacity=".2"/><rect x="17" y="5" width="4" height="16" rx="1" fill="currentColor" stroke="none" opacity=".2"/>',
    iconBg: 'rgba(107,127,74,.12)',
    iconBorder: 'rgba(107,127,74,.3)',
    iconColor: '#6B7F4A',
  },
  {
    value: 'intermediaire',
    label: '⭐⭐ Intermédiaire',
    desc: 'Quelques notions utiles',
    icon: '<rect x="3" y="17" width="4" height="4" rx="1" fill="currentColor" stroke="none"/><rect x="10" y="11" width="4" height="10" rx="1" fill="currentColor" stroke="none"/><rect x="17" y="5" width="4" height="16" rx="1" fill="currentColor" stroke="none" opacity=".2"/>',
    iconBg: 'rgba(184,144,101,.15)',
    iconBorder: 'rgba(184,144,101,.35)',
    iconColor: '#B89065',
  },
  {
    value: 'avance',
    label: '⭐⭐⭐ Avancé',
    desc: 'Expérience recommandée',
    icon: '<rect x="3" y="17" width="4" height="4" rx="1" fill="currentColor" stroke="none"/><rect x="10" y="11" width="4" height="10" rx="1" fill="currentColor" stroke="none"/><rect x="17" y="5" width="4" height="16" rx="1" fill="currentColor" stroke="none"/>',
    iconBg: 'rgba(194,86,47,.12)',
    iconBorder: 'rgba(194,86,47,.3)',
    iconColor: '#C2562F',
  },
];
---
<Layout
  title="Catalogue"
  description={`${total} fiches pédagogiques maker libres de droit — triez par public, durée ou matériel.`}
  hideSuggestions={true}
>
  <Nav current="catalogue" />

  <main class="page">

    <!-- EN-TÊTE -->
    <section class="page-head">
      <span class="section-eyebrow">Catalogue · {total} atelier{total > 1 ? 's' : ''}</span>
      <h1>Bibliothèque d'ateliers</h1>
      <p>Triez, copiez, adaptez. Toutes les fiches sont libres de droit (CC BY-SA), pensées pour être animées sans formation préalable.</p>
    </section>

    <!-- BARRE DE RECHERCHE -->
    <div class="search-bar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/>
      </svg>
      <input
        id="search-input"
        type="search"
        placeholder="Chercher un atelier, une thématique…"
        aria-label="Rechercher"
        autocomplete="off"
      />
      <span class="search-bar__count" id="search-count" aria-live="polite">
        {total}/{total}
      </span>
    </div>

    <!-- FILTRES -->
    <div class="filters" role="group" aria-label="Filtres">

      <div class="filter-group">
        <span class="filter-label">Public</span>
        <button class="filter-chip filter-chip--active" data-filter="public" data-value="tous">Tous</button>
        <button class="filter-chip" data-filter="public" data-value="enfants">Enfants</button>
        <button class="filter-chip" data-filter="public" data-value="ados">Ados</button>
        <button class="filter-chip" data-filter="public" data-value="adultes">Adultes</button>
        <button class="filter-chip" data-filter="public" data-value="famille">Famille</button>
      </div>

      <div class="filter-group">
        <span class="filter-label">Durée</span>
        <button class="filter-chip filter-chip--active" data-filter="duree" data-value="tous">Toute</button>
        <button class="filter-chip" data-filter="duree" data-value="flux-ouvert">⚡ Flux ouvert</button>
        <button class="filter-chip" data-filter="duree" data-value="atelier">🕐 Atelier</button>
        <button class="filter-chip" data-filter="duree" data-value="stage">📅 Stage / Projet</button>
      </div>

      <FilterDropdown id="filter-difficulte" label="Difficulté" options={DIFF_OPTIONS} />

      <button class="filter-chip filter-chip--reuse" id="filter-reuse" aria-pressed="false">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 13L4 18h7"/><path d="M11 18l-2-2"/>
          <path d="M17 13l3 5h-7"/><path d="M13 18l2-2"/>
          <path d="M14 7L11 5 8 7"/><path d="M11 5v6"/>
        </svg>
        Réemploi
      </button>

    </div>

    <!-- GRILLE D'ATELIERS -->
    <div class="workshop-grid" id="workshop-grid">

      {ateliers.length === 0 ? (
        <p class="catalogue-empty">Aucun atelier dans la collection — ajoutez des fichiers dans <code>src/content/ateliers/</code>.</p>
      ) : (
        ateliers.map(atelier => {
          const { titre, accroche, public: pub, duree, difficulte, classification, reemploi, famille } = atelier.data;
          return (
            <a
              class="wcard"
              href={`/ateliers/${atelier.slug}`}
              data-titre={titre.toLowerCase()}
              data-accroche={(accroche ?? '').toLowerCase()}
              data-public={JSON.stringify(pub)}
              data-duree={JSON.stringify(duree)}
              data-difficulte={difficulte}
              data-reemploi={reemploi ? 'true' : 'false'}
              data-famille={famille}
            >
              <div class={`wcard__media ph-photo ${famille === 'carton' || famille === 'kermesse' ? '' : famille === 'mediation' || famille === 'beaverbot' ? 'ph-photo--moss' : 'ph-photo--terracotta'}`}>
                <div class="wcard__badges">
                  {classification === 'classique'
                    ? <span class="badge badge--classique"><Picto name="classique" size={14} />Classique</span>
                    : <span class="badge badge--original"><Picto name="original" size={14} />Original</span>
                  }
                </div>
                {reemploi && (
                  <div class="wcard__reuse">
                    <span class="tag tag--reuse">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M7 13L4 18h7"/><path d="M11 18l-2-2"/>
                        <path d="M17 13l3 5h-7"/><path d="M13 18l2-2"/>
                        <path d="M14 7L11 5 8 7"/><path d="M11 5v6"/>
                      </svg>
                      Réemploi
                    </span>
                  </div>
                )}
                <span class="ph-photo__caption">{famille}</span>
              </div>
              <div class="wcard__body">
                <h3 class="wcard__title">{titre}</h3>
                <p class="wcard__hint">{accroche}</p>
                <div class="wcard__tags">
                  <span class="tag tag--public">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <circle cx="9" cy="9" r="3"/><path d="M3 19c0-3.3 2.7-6 6-6s6 2.7 6 6"/>
                      <circle cx="17" cy="7" r="2.5"/><path d="M14 14c2.7 0 6 1.7 6 5"/>
                    </svg>
                    {pub.map((p: string) => publicLabel[p]).join(' · ')}
                  </span>
                  <span class="tag tag--time">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
                      <circle cx="12" cy="12" r="8.5"/><path d="M12 7v5l3.5 2.5"/>
                    </svg>
                    {duree.map((d: string) => dureeLabel[d]).join(' · ')}
                  </span>
                  <span class="tag tag--mat">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
                    </svg>
                    {difficulteLabel[difficulte]}
                  </span>
                </div>
              </div>
            </a>
          );
        })
      )}

    </div>

  </main>

</Layout>

<script>
  const grid = document.getElementById('workshop-grid')!;
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const countEl = document.getElementById('search-count')!;
  const cards = Array.from(grid.querySelectorAll<HTMLElement>('.wcard'));
  const total = cards.length;

  // Filtre state
  const active: Record<string, string> = { public: 'tous', duree: 'tous', difficulte: 'tous' };
  let reuseOnly = false;
  let query = '';

  function normalize(s: string) {
    return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
  }

  function matchesPublic(card: HTMLElement) {
    if (active.public === 'tous') return true;
    const pubs = JSON.parse(card.dataset.public ?? '[]');
    return pubs.includes(active.public);
  }

  function matchesDuree(card: HTMLElement) {
    if (active.duree === 'tous') return true;
    const durees = JSON.parse(card.dataset.duree ?? '[]');
    return durees.includes(active.duree);
  }

  function matchesDifficulte(card: HTMLElement) {
    if (active.difficulte === 'tous') return true;
    return card.dataset.difficulte === active.difficulte;
  }

  function matchesReuse(card: HTMLElement) {
    return !reuseOnly || card.dataset.reemploi === 'true';
  }

  function matchesSearch(card: HTMLElement) {
    if (!query) return true;
    const q = normalize(query);
    return (
      normalize(card.dataset.titre ?? '').includes(q) ||
      normalize(card.dataset.accroche ?? '').includes(q) ||
      normalize(card.dataset.famille ?? '').includes(q)
    );
  }

  function applyFilters() {
    let visible = 0;
    cards.forEach(card => {
      const show = matchesPublic(card) && matchesDuree(card) && matchesDifficulte(card) && matchesReuse(card) && matchesSearch(card);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    countEl.textContent = `${visible}/${total}`;

    // Vide state
    let empty = grid.querySelector('.catalogue-empty');
    if (visible === 0 && total > 0) {
      if (!empty) {
        empty = document.createElement('p');
        empty.className = 'catalogue-empty';
        empty.textContent = '— Aucun atelier ne correspond à ces filtres —';
        grid.appendChild(empty);
      }
    } else {
      empty?.remove();
    }
  }

  // Chips Public + Durée
  document.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;
      btn.closest('.filter-group')!
        .querySelectorAll<HTMLButtonElement>('.filter-chip')
        .forEach(b => b.classList.remove('filter-chip--active'));
      btn.classList.add('filter-chip--active');
      active[filter] = btn.dataset.value!;
      applyFilters();
    });
  });

  // Dropdown Difficulté
  document.addEventListener('dropdown:change', (e: Event) => {
    const { id, value } = (e as CustomEvent<{ id: string; value: string }>).detail;
    if (id === 'filter-difficulte') {
      active.difficulte = value;
      applyFilters();
    }
  });

  // Toggle réemploi
  const reuseBtn = document.getElementById('filter-reuse')!;
  reuseBtn.addEventListener('click', () => {
    reuseOnly = !reuseOnly;
    reuseBtn.classList.toggle('filter-chip--active', reuseOnly);
    reuseBtn.setAttribute('aria-pressed', String(reuseOnly));
    applyFilters();
  });

  // Recherche
  searchInput.addEventListener('input', () => {
    query = searchInput.value;
    applyFilters();
  });
</script>
