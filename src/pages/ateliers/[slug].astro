---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Picto from '../../components/Picto.astro';

export async function getStaticPaths() {
  const ateliers = await getCollection('ateliers');
  return ateliers.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const {
  titre, accroche, famille, classification, reemploi,
  public: pub, duree, materiel, difficulte,
  fiche_pdf, steps, declinaisons, adaptations, securite,
} = entry.data;

const familleLabel: Record<string, string> = {
  kermesse: 'Kermesse',
  carton: 'Carton',
  machines: 'Machines',
  mediation: 'Médiation',
  beaverbot: 'BeaverBot',
};

const publicLabel: Record<string, string> = {
  'enfants': 'Enfants',
  'ados':    'Ados',
  'adultes': 'Adultes',
  'famille': 'Famille',
};

const dureeLabel: Record<string, string> = {
  'flux-ouvert': '⚡ Flux ouvert',
  'atelier':     '🕐 Atelier',
  'stage':       '📅 Stage / Projet',
};

const dureeTime: Record<string, string> = {
  'flux-ouvert': '20–45 min',
  'atelier':     '1h à 3h',
  'stage':       'plusieurs séances',
};

const difficulteLabel: Record<string, string> = {
  debutant: '⭐ Débutant',
  intermediaire: '⭐⭐ Intermédiaire',
  avance: '⭐⭐⭐ Avancé',
};
---
<Layout title={titre} description={accroche} excludeSlug={entry.slug}>
  <Nav current="catalogue" />

  <main class="page">

    <!-- HERO -->
    <section class="atelier-hero">
      <a class="atelier-back" href="/catalogue">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Catalogue
      </a>

      <div class="atelier-hero__col">
        <div class="atelier-hero__badges">
          {classification === 'classique'
            ? <span class="badge badge--classique"><Picto name="classique" size={14} />Classique</span>
            : <span class="badge badge--original"><Picto name="original" size={14} />Original</span>
          }
          {reemploi && (
            <span class="tag tag--reuse">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M7 13L4 18h7"/><path d="M11 18l-2-2"/>
                <path d="M17 13l3 5h-7"/><path d="M13 18l2-2"/>
                <path d="M14 7L11 5 8 7"/><path d="M11 5v6"/>
              </svg>
              Réemploi dispo
            </span>
          )}
          <span class="label-mono">{familleLabel[famille]}</span>
        </div>

        <h1 class="atelier-hero__title">{titre}</h1>
        <p class="atelier-hero__lead">{accroche}</p>
        {fiche_pdf && (
          <a class="btn btn--accent atelier-hero__dl" href={fiche_pdf} download>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Télécharger la fiche PDF
          </a>
        )}
      </div>

      <div class="atelier-cover">
        <span class="atelier-cover__tape">photo · à venir</span>
      </div>
    </section>

    <!-- EN UN COUP D'ŒIL -->
    <section class="glance" aria-label="En un coup d'œil">
      <div class="glance__title">
        <span>En un coup d'œil</span>
        <span class="label-mono">{familleLabel[famille]}</span>
      </div>
      <dl class="glance__rows">
        <div class="glance__row">
          <span class="glance__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="9" cy="9" r="3"/><path d="M3 19c0-3.3 2.7-6 6-6s6 2.7 6 6"/>
              <circle cx="17" cy="7" r="2.5"/><path d="M14 14c2.7 0 6 1.7 6 5"/>
            </svg>
          </span>
          <div>
            <dt>Public</dt>
            <dd class="pub-chips">
              {pub.map(p => (
                <span class={`pub-chip pub-chip--${p}`}>{publicLabel[p]}</span>
              ))}
            </dd>
          </div>
        </div>
        <div class="glance__row">
          <span class="glance__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
              <circle cx="12" cy="12" r="8.5"/><path d="M12 7v5l3.5 2.5"/>
            </svg>
          </span>
          <div>
            <dt>Durée</dt>
            <dd class="duree-chips">
              {duree.map(d => (
                <span class={`duree-chip duree-chip--${d}`}>
                  {dureeLabel[d]}<span class="duree-chip__time">{dureeTime[d]}</span>
                </span>
              ))}
            </dd>
          </div>
        </div>
        {materiel && (
        <div class="glance__row">
          <span class="glance__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <path d="M3 6h18M16 10a4 4 0 0 1-8 0"/>
            </svg>
          </span>
          <div><dt>Matériel</dt><dd>{materiel}</dd></div>
        </div>
        )}
        <div class="glance__row">
          <span class="glance__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
            </svg>
          </span>
          <div>
            <dt>Difficulté</dt>
            <dd><span class={`diff-chip diff-chip--${difficulte}`}>{difficulteLabel[difficulte]}</span></dd>
          </div>
        </div>
      </dl>
    </section>

    <!-- PAS-À-PAS -->
    {steps && steps.length > 0 && (
      <section class="steps-section">
        <div class="steps-section__head">
          <span class="section-eyebrow">Pas-à-pas · {steps.length} étape{steps.length > 1 ? 's' : ''}</span>
          <h2 style="margin-top:8px">Fabrication</h2>
        </div>
        <div class="steps-section__grid">
          {steps.map((step, i) => (
            <article class="step-card">
              <div class="step-card__media">
                <span class="step-card__num">{i + 1}</span>
                {step.temps && <span class="step-card__time">{step.temps}</span>}
                <span class="ph-photo__caption">étape {i + 1}</span>
              </div>
              <div class="step-card__body">
                <h3 class="step-card__title">{step.titre}</h3>
                <p class="step-card__copy">{step.corps}</p>
                {step.outils.length > 0 && (
                  <div class="step-card__tools">
                    {step.outils.map(o => (
                      <span class="tag" style="background:var(--rm-cream-3);color:var(--text-2)">{o}</span>
                    ))}
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- DÉCLINAISONS -->
    {declinaisons && declinaisons.length > 0 && (
      <section class="declinaisons">
        <h2>Déclinaisons par contexte</h2>
        <p class="declinaisons__intro">L'atelier marche tel quel — mais il gagne souvent à être ajusté au lieu, à l'âge, au temps disponible.</p>
        <div class="declinaisons__list">
          {declinaisons.map(d => (
            <div class={`decl-card decl-card--${d.kind}`}>
              <span class="decl-card__pic" aria-hidden="true">
                {d.kind === 'reuse' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 13L4 18h7"/><path d="M11 18l-2-2"/>
                    <path d="M17 13l3 5h-7"/><path d="M13 18l2-2"/>
                    <path d="M14 7L11 5 8 7"/><path d="M11 5v6"/>
                  </svg>
                )}
                {d.kind === 'time' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                    <circle cx="12" cy="12" r="8.5"/><path d="M12 7v5l3.5 2.5"/>
                  </svg>
                )}
                {(d.kind === 'age' || d.kind === 'context' || d.kind === 'theme') && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="9" r="3"/><path d="M3 19c0-3.3 2.7-6 6-6s6 2.7 6 6"/>
                    <circle cx="17" cy="7" r="2.5"/><path d="M14 14c2.7 0 6 1.7 6 5"/>
                  </svg>
                )}
              </span>
              <div>
                <h3>{d.titre}</h3>
                <p>{d.corps}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- SÉCURITÉ -->
    {securite && securite.length > 0 && (
      <section class="securite-section">
        <span class="section-eyebrow section-eyebrow--terra">Sécurité</span>
        <h2 style="margin-top:8px">Points de vigilance</h2>
        <div class="securite-list">
          {securite.map(s => (
            <article class="securite-card">
              <span class="securite-card__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2L3 7v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z"/>
                </svg>
              </span>
              <div>
                <h3>{s.titre}</h3>
                <p>{s.corps}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- ADAPTATIONS -->
    {adaptations && adaptations.length > 0 && (
      <section class="adapt-section">
        <span class="section-eyebrow">Pour aller plus loin</span>
        <h2 style="margin-top:8px">Adaptations</h2>
        <div class="adapt-grid">
          {adaptations.map(a => (
            <article class={`adapt-card adapt-card--${a.kind}`}>
              <span class="adapt-card__icon" aria-hidden="true">
                {a.kind === 'age' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                  </svg>
                )}
                {a.kind === 'group' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="9" r="3"/><path d="M3 19c0-3.3 2.7-6 6-6s6 2.7 6 6"/>
                    <circle cx="17" cy="7" r="2.5"/><path d="M14 14c2.7 0 6 1.7 6 5"/>
                  </svg>
                )}
                {a.kind === 'weather' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9z"/>
                  </svg>
                )}
                {a.kind === 'location' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                  </svg>
                )}
                {a.kind === 'theme' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 18h6M10 22h4M12 2a7 7 0 0 1 7 7 7.1 7.1 0 0 1-3.5 6.14V17a1 1 0 0 1-1 1h-5a1 1 0 0 1-1-1v-1.86A7.1 7.1 0 0 1 5 9a7 7 0 0 1 7-7z"/>
                  </svg>
                )}
              </span>
              <div>
                <h3>{a.titre}</h3>
                <p>{a.corps}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- TÉLÉCHARGER LA FICHE -->
    {fiche_pdf && (
      <section class="dl-banner">
        <div class="dl-banner__bg-circle"></div>
        <div>
          <h3>Télécharger la fiche pédagogique</h3>
          <p>PDF A4 prêt pour l'atelier — étapes, matériel, variantes.</p>
        </div>
        <div class="dl-banner__actions">
          <a class="btn btn--accent" href={fiche_pdf} download>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Télécharger PDF
          </a>
        </div>
      </section>
    )}

  </main>

</Layout>

<style>
/* Chips public dans "en un coup d'œil" */
.pub-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-top: 4px;
}
.pub-chip {
  display: inline-flex;
  align-items: center;
  padding: 2px 9px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 600;
  font-family: var(--font-display);
  border: 1.5px solid;
}
.pub-chip--enfants  { background: rgba(107,127,74,.12); border-color: rgba(107,127,74,.35); color: #4a5a30; }
.pub-chip--ados     { background: rgba(184,144,101,.14); border-color: rgba(184,144,101,.4); color: #6e4e25; }
.pub-chip--adultes  { background: rgba(194,86,47,.10);  border-color: rgba(194,86,47,.32);  color: #8b3820; }
.pub-chip--famille  { background: rgba(232,97,26,.09);  border-color: rgba(232,97,26,.32);  color: #7a3b0e; }

/* Chips durée */
.duree-chips { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 4px; }
.duree-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 2px 9px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 600;
  font-family: var(--font-display);
  border: 1.5px solid;
}
.duree-chip__time {
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 400;
  padding-left: 5px;
  border-left: 1px solid currentColor;
  opacity: .65;
}
.duree-chip--flux-ouvert { background: rgba(232,97,26,.09);   border-color: rgba(232,97,26,.32);   color: #7a3b0e; }
.duree-chip--atelier     { background: rgba(107,127,74,.12);  border-color: rgba(107,127,74,.35);  color: #4a5a30; }
.duree-chip--stage       { background: rgba(184,144,101,.14); border-color: rgba(184,144,101,.4);  color: #6e4e25; }

/* Chip difficulté */
.diff-chip {
  display: inline-flex;
  align-items: center;
  padding: 2px 9px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 600;
  font-family: var(--font-display);
  border: 1.5px solid;
  margin-top: 4px;
}
.diff-chip--debutant      { background: rgba(107,127,74,.12);  border-color: rgba(107,127,74,.35); color: #4a5a30; }
.diff-chip--intermediaire { background: rgba(184,144,101,.14); border-color: rgba(184,144,101,.4); color: #6e4e25; }
.diff-chip--avance        { background: rgba(194,86,47,.10);   border-color: rgba(194,86,47,.32);  color: #8b3820; }

/* Prose du corps markdown */
.atelier-prose {
  padding-top: 32px;
}
.atelier-prose :global(h2) {
  font-size: 22px;
  letter-spacing: -.02em;
  margin: 28px 0 10px;
}
.atelier-prose :global(h3) {
  font-size: 17px;
  letter-spacing: -.01em;
  margin: 20px 0 8px;
  color: var(--text);
}
.atelier-prose :global(p) {
  font-size: 15px;
  color: var(--text-2);
  line-height: 1.65;
  margin-bottom: 12px;
}
.atelier-prose :global(ul),
.atelier-prose :global(ol) {
  font-size: 14.5px;
  color: var(--text-2);
  line-height: 1.6;
  padding-left: 20px;
  margin-bottom: 14px;
}
.atelier-prose :global(li) { margin-bottom: 4px; }
.atelier-prose :global(strong) { color: var(--text); font-weight: 600; }
.atelier-prose :global(table) {
  width: 100%;
  border-collapse: collapse;
  font-size: 13.5px;
  margin-bottom: 18px;
}
.atelier-prose :global(th) {
  text-align: left;
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--text-3);
  padding: 8px 12px;
  border-bottom: 1.5px solid var(--border);
}
.atelier-prose :global(td) {
  padding: 10px 12px;
  border-bottom: 1px solid var(--rm-cream-3);
  color: var(--text-2);
  vertical-align: top;
}
.atelier-prose :global(tr:last-child td) { border-bottom: 0; }

/* hide connexions section (internal references) */
.atelier-prose :global(h2:last-of-type + ul) { display: none; }

/* Respiration entre sections */
:global(.glance)         { margin-top: 32px; }
:global(.steps-section)  { margin-top: 40px; }
:global(.declinaisons)   { margin-top: 40px; }
:global(.securite-section) { margin-top: 40px; }
:global(.adapt-section)  { margin-top: 40px; }
:global(.dl-banner)      { margin-top: 40px; }

@media (min-width: 880px) {
  :global(.glance)           { margin-top: 56px; }
  :global(.steps-section)    { margin-top: 64px; }
  :global(.declinaisons)     { margin-top: 48px; }
  :global(.securite-section) { margin-top: 48px; }
  :global(.adapt-section)    { margin-top: 48px; }
  :global(.dl-banner)        { margin-top: 64px; }
}

@media (min-width: 880px) {
  .atelier-prose {
    padding: 56px 64px 0;
    max-width: 1320px;
    margin: 0 auto;
  }
  .atelier-prose :global(h2) { font-size: 28px; }
  .atelier-prose :global(p) { font-size: 16px; max-width: 70ch; }
}
</style>
